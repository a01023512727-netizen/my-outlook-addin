# Google Apps Script 웹앱(또는 JSON을 반환하는) URL — 끝에 /exec 등 실제 엔드포인트까지
SCRIPT_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# 견적 탭 — OpenAI 분류 (/api/classify-flight-quote)
# sk- 로 시작하는 키만 넣으세요. Bearer 접두사·따옴표·Authorization: 줄은 넣지 마세요.
OPENAI_API_KEY=sk-...
# 선택. 기본 gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
